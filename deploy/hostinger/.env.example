# Template do .env do deploy temporario no Hostinger.
# Copiar pra .env e preencher os <placeholders> antes do bootstrap.
#
# Gerar SECRET_KEY:       python -c "import secrets; print(secrets.token_hex(32))"
# Gerar ENCRYPTION_KEY:   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Gerar POSTGRES_PASSWORD: openssl rand -hex 24

# Tag da imagem (deploy-flowertex.yml sed-a isso com o SHA do commit)
IMAGE_TAG=main

# Postgres
POSTGRES_USER=flowertex
POSTGRES_PASSWORD=<openssl rand -hex 24>
POSTGRES_DB=flowertex
DATABASE_URL=postgresql+asyncpg://flowertex:<mesmo-password-acima>@postgres:5432/flowertex

# Redis (interno, sem auth — escopo curto)
REDIS_URL=redis://redis:6379/0

# App secrets
SECRET_KEY=<token_hex(32)>
ENCRYPTION_KEY=<Fernet.generate_key()>

# URLs / CORS
CORS_ORIGINS=["https://flowertex.idlehub.com.br"]
FRONTEND_URL=https://flowertex.idlehub.com.br

# Frontend Nuxt — URL absoluta (sobrescreve build-time /api/v1 via runtimeConfig)
NUXT_PUBLIC_API_BASE=https://flowertex.idlehub.com.br/api/v1
NUXT_PUBLIC_MOCK_MODE=false
NUXT_PUBLIC_SITE_URL=https://flowertex.idlehub.com.br

# Saga runner — real em prod (credenciais via /settings em runtime).
# Mock e fallback pra dev local sem stack Databricks.
SAGA_RUNNER=real

# Omni gateway — chave compartilhada entre backend e omni. Gerar:
#   echo "omni_sk_$(openssl rand -hex 16)"
OMNI_API_KEY=<omni_sk_xxx>

