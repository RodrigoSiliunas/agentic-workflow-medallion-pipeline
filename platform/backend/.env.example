# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flowertex

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (SEPARADA do JWT — para credenciais de empresa)
ENCRYPTION_KEY=change-me-encryption-key

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Omni (gateway WhatsApp/Discord/Telegram)
OMNI_API_URL=http://localhost:8882/api/v2
OMNI_API_KEY=
OMNI_WEBHOOK_SECRET=

# App
DEBUG=true
# Seed idempotente dos 3 templates no lifespan startup
AUTO_SEED=true
# Runner da saga de deploy: "mock" (default, sleeps+logs fake) ou "terraform"
# ("terraform" ainda e um stub, vai lancar NotImplementedError na execucao)
SAGA_RUNNER=real
